{
  "name": "@choksheak/ts-utils",
  "license": "The Unlicense",
  "version": "0.3.8",
  "packageManager": "pnpm@10.18.3",
  "description": "Random Typescript utilities with support for full tree-shaking",
  "private": false,
  "sideEffects": false,
  "scripts": {
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "tsc": "tsc",
    "ft": "pnpm run fix && pnpm run tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "pnpm run lint && pnpm run tsc && pnpm run build && pnpm run test",
    "ls": "lint-staged",
    "docs": "typedoc",
    "clean": "rm -rf dist",
    "build": "tsup src/*",
    "gen-types": "tsc --emitDeclarationOnly --declaration",
    "gen-exports": "tsx scripts/gen-exports.ts",
    "pkg": "scripts/package.sh",
    "pub": "pnpm publish dist/ --access=public",
    "commit": "git add . && git commit -m 'Release '`bump-version get`",
    "release": "pnpm run clean && bump-version && pnpm install && pnpm run ci && pnpm run pkg && pnpm run commit && pnpm run pub",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "echo Using `eslint --fix` will revert changes without printing errors!",
      "pnpm run lint"
    ],
    "*.{ts,tsx}": [
      "echo `tsc-files --noEmit` cannot read *.module.css files",
      "bash -c 'pnpm exec tsc'"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/choksheak/ts-utils.git"
  },
  "keywords": [
    "chok",
    "TS",
    "utils",
    "typescript",
    "library"
  ],
  "author": "ChokSheak Lau",
  "type": "commonjs",
  "homepage": "https://github.com/choksheak/ts-utils#readme",
  "devDependencies": {
    "@choksheak/bump-version": "^0.1.2",
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.38.0",
    "@swc/core": "^1.14.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-config": "^0.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "fake-indexeddb": "^6.0.0",
    "globals": "^16.4.0",
    "jest-environment-jsdom": "^29.7.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.6",
    "mock-local-storage": "^1.1.24",
    "only-allow": "^1.2.2",
    "prettier": "^3.6.2",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.0.3"
  }
}
